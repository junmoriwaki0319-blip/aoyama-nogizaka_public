{
  "regions": ["hnd1"],
  "functions": {
    "api/edinet/**/*.js": {
      "maxDuration": 60
    },
    "api/stock-prices.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/yahoo/:code", "destination": "/api/yahoo/:code" },
    { "source": "/api/stock/:code", "destination": "/api/stock/:code" },
    { "source": "/api/batch", "destination": "/api/batch" },
    { "source": "/api/stock-prices", "destination": "/api/stock-prices" },
    { "source": "/api/edinet/search/:code", "destination": "/api/edinet/search/:code" },
    { "source": "/api/edinet/xbrl/:docID", "destination": "/api/edinet/xbrl/:docID" },
    { "source": "/api/edinet/land-parcels/:docID", "destination": "/api/edinet/land-parcels/:docID" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://aoyama-nogizaka.com" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    },
    {
      "source": "/(.*).png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" }
      ]
    }
  ]
}
